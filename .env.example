# --- Replit-managed (do NOT set manually) ---
# DATABASE_URL=postgres://...
# SESSION_SECRET=...

# --- Stripe (real adapter; gateway is `not configured` until both keys are set) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLIC_KEY=pk_test_xxx           # frontend only

# --- PayTabs (real request structure; UAE region by default) ---
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_REGION=ARE                       # ARE | SAU | OMN | JOR | EGY | GLOBAL

# --- Telr (real request structure; test mode on by default) ---
TELR_STORE_ID=
TELR_AUTH_KEY=
TELR_TEST_MODE=1                         # 1 = test, 0 = live

# --- Platform defaults ---
DEFAULT_PAYMENT_GATEWAY=mock             # mock | stripe | paytabs | telr | manual
PLATFORM_CURRENCY=AED
PLATFORM_FEE_PERCENTAGE=10

# --- Manual bank transfer details (shown to clients on the manual flow) ---
MANUAL_BANK_ACCOUNT_NAME=ATMEMLY Marketplace LLC
MANUAL_BANK_NAME=Emirates NBD
MANUAL_BANK_IBAN=AE000000000000000000000
MANUAL_BANK_SWIFT=EBILAEAD
